<!doctype html>
<html lang="tr">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover">
    <meta name="theme-color" content="#050606">
    <title>KARABASAN//NULL</title>
    <style>
      :root {
        color-scheme: dark;
        --black: #050606;
        --panel: #090b0b;
        --ink: #edf2f1;
        --soft: #a9b2b0;
        --dim: #626b69;
        --line: #252b2a;
        --signal: #b9f6dc;
        --warning: #ff6868;
        --panic: 0;
      }

      * {
        box-sizing: border-box;
      }

      html,
      body {
        width: 100%;
        height: 100%;
        margin: 0;
        overflow: hidden;
        background: var(--black);
      }

      body {
        color: var(--ink);
        font-family: "Courier New", Courier, monospace;
        font-size: 15px;
        line-height: 1.5;
        letter-spacing: 0;
        cursor: crosshair;
      }

      body::before {
        content: "";
        position: fixed;
        z-index: 8;
        inset: 0;
        background: repeating-linear-gradient(
          0deg,
          rgba(255, 255, 255, 0.018) 0,
          rgba(255, 255, 255, 0.018) 1px,
          transparent 1px,
          transparent 4px
        );
        opacity: calc(0.55 + var(--panic) * 0.06);
        box-shadow: inset 0 0 150px rgba(0, 0, 0, 0.94);
        pointer-events: none;
      }

      body::after {
        content: "";
        position: fixed;
        z-index: 9;
        top: 0;
        right: 0;
        left: 0;
        height: 2px;
        background: rgba(237, 242, 241, 0.3);
        opacity: 0;
        pointer-events: none;
      }

      body[data-level="2"]::after,
      body[data-level="3"]::after {
        animation: tracking 3.1s steps(1, end) infinite;
      }

      body[data-level="3"] .app {
        animation: unstable 760ms steps(2, end) infinite;
      }

      body[data-level="3"] #field {
        opacity: 0.72;
      }

      body.flash {
        animation: flash 110ms steps(2, end);
      }

      #field {
        position: fixed;
        z-index: 0;
        inset: 0;
        width: 100%;
        height: 100%;
        opacity: 0.42;
        image-rendering: pixelated;
        pointer-events: none;
      }

      .app {
        position: relative;
        z-index: 2;
        display: flex;
        flex-direction: column;
        width: min(100%, 1180px);
        height: 100dvh;
        margin: 0 auto;
        padding: max(14px, env(safe-area-inset-top)) max(16px, env(safe-area-inset-right)) max(14px, env(safe-area-inset-bottom)) max(16px, env(safe-area-inset-left));
      }

      .topbar {
        display: grid;
        flex: 0 0 42px;
        grid-template-columns: minmax(0, 1fr) auto auto;
        align-items: start;
        gap: 24px;
        border-bottom: 1px solid var(--line);
        color: var(--dim);
        font-size: 11px;
        text-transform: uppercase;
      }

      .brand {
        color: var(--ink);
        font-weight: 700;
      }

      .brand span {
        color: var(--signal);
      }

      .top-state {
        max-width: 38vw;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
      }

      .workspace {
        display: grid;
        flex: 1 1 auto;
        grid-template-columns: minmax(0, 1fr) 226px;
        min-height: 0;
      }

      .terminal {
        display: flex;
        min-width: 0;
        min-height: 0;
        flex-direction: column;
        padding-right: 22px;
      }

      .output {
        flex: 1 1 auto;
        min-height: 0;
        padding: 22px 0 26px;
        overflow-x: hidden;
        overflow-y: auto;
        scrollbar-color: var(--line) transparent;
        scrollbar-width: thin;
        mask-image: linear-gradient(to bottom, transparent 0, #000 16px, #000 100%);
      }

      .line {
        width: 100%;
        min-height: 1.5em;
        margin: 0 0 7px;
        white-space: pre-wrap;
        overflow-wrap: anywhere;
        text-shadow: 0 0 8px rgba(237, 242, 241, 0.12);
      }

      .line.system {
        color: var(--dim);
      }

      .line.user {
        color: var(--soft);
      }

      .line.alert {
        color: var(--warning);
        text-transform: uppercase;
      }

      .line.file {
        color: var(--signal);
      }

      .line.title {
        margin-top: 6px;
        color: #fff;
        font-weight: 700;
        text-transform: uppercase;
      }

      .line.typing::after {
        content: "_";
        margin-left: 2px;
        color: #fff;
        animation: blink 560ms steps(1, end) infinite;
      }

      .input-row {
        display: flex;
        flex: 0 0 40px;
        align-items: center;
        min-width: 0;
        border-top: 1px solid var(--line);
      }

      .prompt {
        flex: 0 0 auto;
        max-width: 42%;
        padding-right: 10px;
        overflow: hidden;
        color: var(--signal);
        text-overflow: ellipsis;
        white-space: nowrap;
      }

      #answer {
        flex: 1 1 auto;
        min-width: 0;
        padding: 0;
        border: 0;
        border-radius: 0;
        outline: 0;
        color: #fff;
        background: transparent;
        caret-color: var(--signal);
        font: inherit;
        letter-spacing: 0;
        cursor: text;
      }

      #answer:read-only {
        caret-color: transparent;
      }

      .send {
        display: grid;
        flex: 0 0 34px;
        width: 34px;
        height: 34px;
        padding: 0;
        place-items: center;
        border: 0;
        border-radius: 0;
        outline: 0;
        color: var(--dim);
        background: transparent;
        font: 20px/1 "Courier New", Courier, monospace;
        cursor: pointer;
      }

      .send:hover,
      .send:focus-visible {
        color: var(--signal);
      }

      .telemetry {
        min-width: 0;
        padding: 22px 0 0 20px;
        border-left: 1px solid var(--line);
        color: var(--dim);
        font-size: 11px;
        text-transform: uppercase;
      }

      .telemetry-title {
        margin-bottom: 24px;
        color: var(--ink);
        font-weight: 700;
      }

      .identity {
        margin-bottom: 22px;
      }

      .identity-label,
      .meter-label,
      .observation-label {
        display: flex;
        justify-content: space-between;
        gap: 8px;
        margin-bottom: 7px;
      }

      .identity-value {
        min-height: 23px;
        color: var(--signal);
        font-size: 14px;
        overflow-wrap: anywhere;
      }

      .meter {
        margin-bottom: 17px;
      }

      .meter-track {
        width: 100%;
        height: 3px;
        overflow: hidden;
        background: var(--line);
      }

      .meter-fill {
        width: 0;
        height: 100%;
        background: var(--signal);
        transition: width 380ms ease;
      }

      .observations {
        margin-top: 28px;
        padding-top: 16px;
        border-top: 1px solid var(--line);
      }

      .observation-list {
        display: grid;
        gap: 9px;
        min-height: 82px;
        color: var(--soft);
      }

      .observation-list span::before {
        content: "> ";
        color: var(--signal);
      }

      .pulse {
        animation: pulse 420ms steps(2, end);
      }

      @keyframes blink {
        0%,
        48% {
          opacity: 1;
        }
        49%,
        100% {
          opacity: 0;
        }
      }

      @keyframes flash {
        0% {
          filter: invert(0);
          transform: translateX(0);
        }
        45% {
          filter: invert(0.12);
          transform: translateX(3px);
        }
        100% {
          filter: invert(0);
          transform: translateX(0);
        }
      }

      @keyframes pulse {
        0%,
        100% {
          color: var(--dim);
        }
        50% {
          color: var(--signal);
        }
      }

      @keyframes unstable {
        0%,
        88%,
        100% {
          transform: translate(0, 0);
        }
        89% {
          transform: translate(1px, 0);
        }
        91% {
          transform: translate(-2px, 1px);
        }
        93% {
          transform: translate(0, -1px);
        }
      }

      @keyframes tracking {
        0%,
        84%,
        100% {
          top: 8%;
          opacity: 0;
        }
        85% {
          top: 23%;
          opacity: 0.45;
        }
        87% {
          top: 76%;
          opacity: 0.18;
        }
        89% {
          opacity: 0;
        }
      }

      @media (max-width: 760px) {
        body {
          font-size: 14px;
        }

        .app {
          padding: max(12px, env(safe-area-inset-top)) max(13px, env(safe-area-inset-right)) max(12px, env(safe-area-inset-bottom)) max(13px, env(safe-area-inset-left));
        }

        .topbar {
          grid-template-columns: minmax(0, 1fr) auto;
          gap: 12px;
        }

        .top-state {
          display: none;
        }

        .workspace {
          grid-template-columns: minmax(0, 1fr);
        }

        .terminal {
          padding-right: 0;
        }

        .telemetry {
          display: none;
        }

        .output {
          padding-top: 18px;
          padding-bottom: 20px;
        }

        .line {
          margin-bottom: 6px;
        }

        .prompt {
          max-width: 36%;
          font-size: 12px;
        }
      }

      @media (prefers-reduced-motion: reduce) {
        body,
        body::after,
        .app,
        .line.typing::after,
        .pulse {
          animation: none !important;
        }

        .meter-fill {
          transition: none;
        }
      }
    </style>
  </head>
  <body data-level="0">
    <canvas id="field" aria-hidden="true"></canvas>
    <main class="app" aria-label="Karabasan interaktif terminal oyunu">
      <header class="topbar">
        <div class="brand">KARABASAN<span>//NULL</span></div>
        <div id="top-state" class="top-state">BAĞLANTI BEKLENİYOR</div>
        <time id="clock">00:00:00</time>
      </header>

      <div class="workspace">
        <section class="terminal" aria-label="Terminal">
          <div id="output" class="output" aria-live="polite"></div>
          <form id="command" class="input-row" autocomplete="off">
            <span id="prompt" class="prompt">&gt;</span>
            <input id="answer" type="text" maxlength="96" aria-label="Cevabın" autocomplete="off" autocapitalize="off" spellcheck="false" readonly>
            <button class="send" type="submit" aria-label="Gönder" title="Gönder">↵</button>
          </form>
        </section>

        <aside class="telemetry" aria-label="Canlı analiz">
          <div class="telemetry-title">CANLI ANALİZ</div>
          <div class="identity">
            <div class="identity-label"><span>KULLANICI</span><span id="session-id">#0000</span></div>
            <div id="identity" class="identity-value">TANIMSIZ</div>
          </div>

          <div class="meter">
            <div class="meter-label"><span>SİNİR</span><span id="nerve-value">24</span></div>
            <div class="meter-track"><div id="nerve-meter" class="meter-fill"></div></div>
          </div>
          <div class="meter">
            <div class="meter-label"><span>EGO</span><span id="ego-value">18</span></div>
            <div class="meter-track"><div id="ego-meter" class="meter-fill"></div></div>
          </div>
          <div class="meter">
            <div class="meter-label"><span>KAOS</span><span id="chaos-value">12</span></div>
            <div class="meter-track"><div id="chaos-meter" class="meter-fill"></div></div>
          </div>
          <div class="meter">
            <div class="meter-label"><span>DÜRÜSTLÜK</span><span id="truth-value">50</span></div>
            <div class="meter-track"><div id="truth-meter" class="meter-fill"></div></div>
          </div>

          <div class="observations">
            <div class="observation-label"><span>GÖZLEMLER</span><span id="latency">-- MS</span></div>
            <div id="observation-list" class="observation-list">
              <span>VERİ BEKLENİYOR</span>
            </div>
          </div>
        </aside>
      </div>
    </main>

    <script>
      (() => {
        "use strict";

        const output = document.querySelector("#output");
        const form = document.querySelector("#command");
        const answer = document.querySelector("#answer");
        const prompt = document.querySelector("#prompt");
        const clock = document.querySelector("#clock");
        const topState = document.querySelector("#top-state");
        const identity = document.querySelector("#identity");
        const sessionId = document.querySelector("#session-id");
        const latency = document.querySelector("#latency");
        const observationList = document.querySelector("#observation-list");
        const field = document.querySelector("#field");
        const context = field.getContext("2d", { alpha: true });
        const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)");

        const meterNodes = {
          nerve: {
            value: document.querySelector("#nerve-value"),
            meter: document.querySelector("#nerve-meter"),
          },
          ego: {
            value: document.querySelector("#ego-value"),
            meter: document.querySelector("#ego-meter"),
          },
          chaos: {
            value: document.querySelector("#chaos-value"),
            meter: document.querySelector("#chaos-meter"),
          },
          truth: {
            value: document.querySelector("#truth-value"),
            meter: document.querySelector("#truth-meter"),
          },
        };

        const phases = {
          NAME: "name",
          AGE: "age",
          BATTERY: "battery",
          SEEN: "seen",
          SLEEP: "sleep",
          THOUGHT: "thought",
          DOOR: "door",
          LIE: "lie",
          REACTION_READY: "reaction-ready",
          REACTION_WAIT: "reaction-wait",
          REACTION_HIT: "reaction-hit",
          SHELL: "shell",
          CONFESSION: "confession",
          EXIT: "exit",
          BARGAIN: "bargain",
          ENDED: "ended",
        };

        const roastPool = [
          "Özgüvenin Wi-Fi gibi: çekiyor görünüyor, internete çıkmıyor.",
          "Cevabın geldi. Mantık hâlâ yolda.",
          "Bunu düşünerek yazdıysan durum daha ciddi.",
          "Kendini gizemli sanıyorsun. Sadece kısa cevap veriyorsun.",
          "Seni yargılamıyorum. Sistem otomatik yaptı.",
          "Beynin yazıyor... Mesaj hâlâ gelmedi.",
          "Bu cevabı savunmak zorunda kalırsan beni karıştırma.",
          "İnsan bazen susmalı. Sen deneysel gidiyorsun.",
        ];

        const shellJokes = [
          "Bilgisayar neden terapiye gitmiş? Sürekli geçmişini siliyormuş. Sen de bir düşün.",
          "Sana bir sistem şakası yapardım ama kaldıracak donanım görünmüyor.",
          "Kendine gel dedim. Konum bulunamadı.",
          "Hayat kısa. Senin cevaplar daha kısa.",
          "Beni güldür dedin. Kamerayı açmadım, merak etme.",
        ];

        const curseReplies = [
          "Klavyeye sinirlenme. O da seni seçmedi.",
          "Bu kadar siniri üç kelimeye sığdırman verimli.",
          "Hakaret algılandı. Argüman yine bulunamadı.",
          "Sesini yükseltemeyince harfleri kirletmişsin.",
        ];

        let state;
        let locked = true;
        let skipTyping = false;
        let reactionTimer = 0;
        let reactionStartedAt = 0;
        let earlyClicks = 0;
        let observations = [];
        let particles = [];
        let pointer = { x: -1000, y: -1000 };
        let lastFrame = 0;

        const randomFrom = (items) => items[Math.floor(Math.random() * items.length)];
        const sleep = (milliseconds) => new Promise((resolve) => setTimeout(resolve, milliseconds));
        const clamp = (value) => Math.max(0, Math.min(100, Math.round(value)));

        function freshState() {
          return {
            phase: phases.NAME,
            name: "",
            age: 0,
            battery: 0,
            ignoredMessage: false,
            sleepHour: 0,
            thought: "",
            openedDoor: false,
            lieChoice: 0,
            confession: "",
            reaction: 0,
            commandCount: 0,
            exitRevealed: false,
            traits: {
              nerve: 24,
              ego: 18,
              chaos: 12,
              truth: 50,
            },
          };
        }

        function normalize(value) {
          return value.toLocaleLowerCase("tr-TR").trim();
        }

        function isYes(value) {
          return ["e", "evet", "evt", "olur", "açarım", "acarim", "tabii", "tamam"].includes(normalize(value));
        }

        function isNo(value) {
          return ["h", "hayır", "hayir", "yok", "açmam", "acmam", "asla", "istemem"].includes(normalize(value));
        }

        function setClock() {
          clock.textContent = new Date().toLocaleTimeString("tr-TR", { hour12: false });
        }

        function setTopState(text) {
          topState.textContent = text;
          topState.classList.remove("pulse");
          void topState.offsetWidth;
          topState.classList.add("pulse");
        }

        function setPrompt(text = ">") {
          prompt.textContent = text;
        }

        function setLevel(level) {
          document.body.dataset.level = String(level);
          document.documentElement.style.setProperty("--panic", String(level));
        }

        function flash() {
          if (reduceMotion.matches) return;
          document.body.classList.remove("flash");
          void document.body.offsetWidth;
          document.body.classList.add("flash");
        }

        function setLocked(nextLocked) {
          locked = nextLocked;
          answer.readOnly = nextLocked;
          if (!nextLocked) answer.focus({ preventScroll: true });
        }

        function scrollToEnd() {
          output.scrollTop = output.scrollHeight;
        }

        function addLine(text, kind = "system") {
          const line = document.createElement("div");
          line.className = `line ${kind}`;
          line.textContent = text;
          output.appendChild(line);
          scrollToEnd();
          return line;
        }

        async function typeLine(text, kind = "bot", speed = 18) {
          const line = document.createElement("div");
          line.className = `line ${kind} typing`;
          output.appendChild(line);
          skipTyping = false;

          for (let index = 0; index < text.length; index += 1) {
            line.textContent += text[index];
            scrollToEnd();
            if (skipTyping || reduceMotion.matches) {
              line.textContent = text;
              break;
            }
            const punctuationPause = ".?!:".includes(text[index]) ? speed * 4 : 0;
            await sleep(speed + Math.random() * 11 + punctuationPause);
          }

          line.classList.remove("typing");
          await sleep(skipTyping ? 30 : 95);
          return line;
        }

        async function say(lines, kind = "bot", speed = 18) {
          const list = Array.isArray(lines) ? lines : [lines];
          for (const text of list) await typeLine(text, kind, speed);
        }

        async function ask(text) {
          await say(text);
          setLocked(false);
        }

        function updateTelemetry() {
          identity.textContent = state.name ? state.name.toLocaleUpperCase("tr-TR") : "TANIMSIZ";
          for (const [key, nodes] of Object.entries(meterNodes)) {
            const value = clamp(state.traits[key]);
            state.traits[key] = value;
            nodes.value.textContent = String(value).padStart(2, "0");
            nodes.meter.style.width = `${value}%`;
          }
        }

        function changeTraits(changes) {
          for (const [key, amount] of Object.entries(changes)) {
            state.traits[key] = clamp(state.traits[key] + amount);
          }
          updateTelemetry();
        }

        function observe(text) {
          observations.unshift(text.toLocaleUpperCase("tr-TR"));
          observations = observations.slice(0, 3);
          observationList.replaceChildren();
          for (const item of observations) {
            const node = document.createElement("span");
            node.textContent = item;
            observationList.appendChild(node);
          }
        }

        function profileLabel() {
          const { nerve, ego, chaos, truth } = state.traits;
          if (chaos >= 68) return "YÜRÜYEN BİLDİRİM SESİ";
          if (ego >= 68) return "KENDİ FRAGMANININ BAŞROLÜ";
          if (nerve >= 68) return "KARANLIKTA BUZDOLABI AÇAN";
          if (truth >= 72) return "ŞÜPHELİ DERECEDE DÜRÜST";
          if (truth <= 30) return "GERÇEĞİ UÇAK MODUNA ALAN";
          return "NORMAL GİBİ YAPAN";
        }

        function riskScore() {
          const { nerve, ego, chaos, truth } = state.traits;
          return clamp((nerve + ego + chaos + (100 - truth)) / 4 + state.commandCount * 2);
        }

        async function maybeRoast(chance = 0.34) {
          if (Math.random() > chance) return;
          await say(randomFrom(roastPool), "system");
        }

        async function handleInterruption(value) {
          const text = normalize(value);
          const curses = ["siktir", "salak", "aptal", "mal", "gerizekalı", "gerizekali", "orospu", "piç", "pic"];

          if (curses.some((word) => text.includes(word))) {
            changeTraits({ nerve: 4, chaos: 5, truth: -2 });
            flash();
            await say(randomFrom(curseReplies));
            return true;
          }
          if (["kimsin", "sen kimsin", "nesin"].includes(text)) {
            changeTraits({ nerve: 2, chaos: 2 });
            await say("Bir sekmeyi kapatınca bittiğini sandığın şeyim.");
            return true;
          }
          if (["sana ne", "sanane"].includes(text)) {
            changeTraits({ ego: 5, nerve: 3 });
            await say("Merak etme, özgeçmişini beğenip işe almayacağım.");
            return true;
          }
          if (text === "karabasan") {
            changeTraits({ chaos: 3 });
            await say("Adımı tekrar etmek beni çağırmaz. Zaten açtın.");
            return true;
          }
          if (["yardım", "yardim", "help"].includes(text)) {
            await say("Yardım dosyası var. Sana erişim yetkisi yok.", "system");
            return true;
          }
          if (["kaç", "kac", "çık", "cik"].includes(text)) {
            changeTraits({ nerve: -2, ego: 2 });
            await say("Daha giriş formundasın. Bu hızla kaçış değil, ayıp olur.");
            return true;
          }
          if (["bilmiyorum", "bilmem"].includes(text) && state.phase !== phases.THOUGHT) {
            changeTraits({ truth: 3, ego: -2 });
            await say("En dürüst cevabın. Yanlış soruda kullandın.");
            return true;
          }
          return false;
        }

        async function processName(value) {
          const clean = value.replace(/\s+/g, " ").trim().slice(0, 24);
          if (clean.length < 2) {
            await ask("Bu isim değil, klavyenin öksürüğü. Tekrar.");
            return;
          }
          if (/\d/.test(clean)) {
            changeTraits({ chaos: 4 });
            await ask("İsmine sayı koymuşsun. 2007 MSN ruhu algılandı. Gerçek adın?");
            return;
          }

          state.name = clean;
          updateTelemetry();
          observe("İsim alındı");
          changeTraits({ ego: clean.length > 10 ? 4 : 1 });

          if (normalize(clean) === "emre") {
            await say(["Emre.", "Dört harf, yüksek özgüven. Riskli kombinasyon."]);
          } else if (clean.length >= 12) {
            await say(`${clean}... İsmin yüklenirken oturum yaşlandı.`);
          } else {
            await say(`${clean}. Kısa süreli belleğe alındın. Pencere kapanınca yoksun.`);
          }

          state.phase = phases.AGE;
