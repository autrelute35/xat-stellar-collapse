          setLocked(true);

          if (state.phase === phases.ENDED) {
            await boot(false);
            return;
          }
          if (state.phase === phases.REACTION_HIT) {
            await processReaction();
            return;
          }
          if (state.phase === phases.SHELL) {
            await processShell(value);
            return;
          }
          if (state.phase === phases.CONFESSION) {
            await processConfession(value);
            return;
          }
          if (state.phase === phases.EXIT) {
            await processExit(value);
            return;
          }
          if (state.phase === phases.BARGAIN) {
            await processBargain(value);
            return;
          }
          if (await handleInterruption(value)) {
            setLocked(false);
            return;
          }

          if (state.phase === phases.NAME) await processName(value);
          else if (state.phase === phases.AGE) await processAge(value);
          else if (state.phase === phases.BATTERY) await processBattery(value);
          else if (state.phase === phases.SEEN) await processSeen(value);
          else if (state.phase === phases.SLEEP) await processSleep(value);
          else if (state.phase === phases.THOUGHT) await processThought(value);
          else if (state.phase === phases.DOOR) await processDoor(value);
          else if (state.phase === phases.LIE) await processLie(value);
          else if (state.phase === phases.REACTION_READY) await processReactionReady(value);
        }

        async function boot(firstBoot = true) {
          window.clearTimeout(reactionTimer);
          output.replaceChildren();
          state = freshState();
          observations = [];
          earlyClicks = 0;
          setLevel(0);
          setPrompt(">");
          setTopState("BAĞLANTI KURULUYOR");
          observationList.innerHTML = "<span>VERİ BEKLENİYOR</span>";
          updateTelemetry();
          setLocked(true);

          try {
            localStorage.removeItem("karabasan-terminal-memory");
          } catch (_) {
            // Eski sürümün kaydı varsa sessizce yok sayılır.
          }

          if (firstBoot) {
            addLine("NULL BIOS 6.6.6", "system");
            await sleep(170);
            addLine("Bellek aranıyor....................YOK", "system");
            await sleep(210);
            addLine("Kamera aranıyor....................YOK", "system");
            await sleep(190);
            addLine("Kullanıcı hataları aranıyor........BOL", "system");
            await sleep(300);
            addLine("C:\\NULL> karabasan.exe --misafir", "user");
            await sleep(420);
            flash();
          }

          sessionId.textContent = `#${Math.floor(1000 + Math.random() * 9000)}`;
          setTopState("OTURUM AÇIK / KAYIT KAPALI");
          await say([
            "merhaba.",
            "ben karabasan.",
            "Kameran yok. Mikrofonun yok. Rahatlama; kendini zaten yazacaksın.",
          ]);
          await ask("Adın ne?");
        }

        function resizeField() {
          const ratio = Math.min(window.devicePixelRatio || 1, 1.5);
          field.width = Math.floor(window.innerWidth * ratio);
          field.height = Math.floor(window.innerHeight * ratio);
          field.style.width = `${window.innerWidth}px`;
          field.style.height = `${window.innerHeight}px`;
          context.setTransform(ratio, 0, 0, ratio, 0, 0);
          const count = Math.max(28, Math.min(105, Math.floor(window.innerWidth / 13)));
          particles = Array.from({ length: count }, () => ({
            x: Math.random() * window.innerWidth,
            y: Math.random() * window.innerHeight,
            speed: 3 + Math.random() * 14,
            size: Math.random() > 0.9 ? 1.5 : 0.65,
            alpha: 0.05 + Math.random() * 0.2,
          }));
        }

        function drawField(time = 0) {
          const elapsed = Math.min(34, time - lastFrame || 16) / 1000;
          lastFrame = time;
          context.clearRect(0, 0, window.innerWidth, window.innerHeight);

          for (const particle of particles) {
            const dx = pointer.x - particle.x;
            const dy = pointer.y - particle.y;
            const distance = Math.hypot(dx, dy);
            if (distance < 120) {
              particle.x -= dx * 0.0018;
              particle.y -= dy * 0.0018;
            }
            particle.y += particle.speed * elapsed * (1 + Number(document.body.dataset.level || 0) * 0.45);
            if (particle.y > window.innerHeight + 3) {
              particle.y = -3;
              particle.x = Math.random() * window.innerWidth;
            }
            context.fillStyle = `rgba(185,246,220,${particle.alpha})`;
            context.fillRect(Math.round(particle.x), Math.round(particle.y), particle.size, particle.size * 4);
          }

          if (Number(document.body.dataset.level || 0) >= 2 && Math.random() > 0.94) {
            context.fillStyle = "rgba(255,104,104,0.08)";
            context.fillRect(0, Math.random() * window.innerHeight, window.innerWidth, 1);
          }

          if (!reduceMotion.matches) requestAnimationFrame(drawField);
        }

        form.addEventListener("submit", (event) => {
          event.preventDefault();
          if (locked) {
            skipTyping = true;
            return;
          }

          const value = answer.value.trim();
          const emptyAllowed = [phases.REACTION_HIT, phases.ENDED].includes(state.phase);
          if (!value && !emptyAllowed) return;
          answer.value = "";
          addLine(`${prompt.textContent} ${value || "[ENTER]"}`, "user");
          route(value);
        });

        document.addEventListener("pointerdown", (event) => {
          pointer.x = event.clientX;
          pointer.y = event.clientY;
          if (locked) {
            skipTyping = true;
            if (state.phase === phases.REACTION_WAIT) earlyClicks += 1;
          } else if (!event.target.closest("button")) {
            answer.focus({ preventScroll: true });
          }
        });

        document.addEventListener("pointermove", (event) => {
          pointer.x = event.clientX;
          pointer.y = event.clientY;
        });

        document.addEventListener("keydown", (event) => {
          if (locked && event.key === "Enter") {
            skipTyping = true;
            if (state.phase === phases.REACTION_WAIT) earlyClicks += 1;
          }
        });

        window.addEventListener("resize", resizeField);
        setClock();
        window.setInterval(setClock, 1000);
        window.setInterval(() => {
          latency.textContent = `${18 + Math.floor(Math.random() * 83)} MS`;
        }, 1450);
        resizeField();
        if (reduceMotion.matches) drawField(16);
        else requestAnimationFrame(drawField);
        boot();
      })();
    </script>
  </body>
</html>
